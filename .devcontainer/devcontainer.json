{
  "name": "OSN Lab Hemat Storage",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "runArgs": [
    "--device=/dev/net/tun",
    "--device=/dev/kvm",
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--add-host=host.docker.internal:host-gateway"
  ],
  "remoteUser": "root",
  "postCreateCommand": "apt-get update && apt-get install -y curl && curl -fsSL https://tailscale.com/install.sh | sh",
  "postStartCommand": "sudo chmod 666 /dev/kvm",
  "forwardPorts": [3000, 11434],
  "portsAttributes": {
    "3000": { "label": "Open WebUI", "onAutoForward": "openBrowser" },
    "11434": { "label": "Ollama API", "onAutoForward": "silent" }
  }
}
